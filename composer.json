{
  "name": "oasys/validator",
  "description": "Lightweight validator for associative arrays with fluent API, custom rules, nested schemas, attribute binding, and message templating",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "validation",
    "validator",
    "payload",
    "array",
    "schema"
  ],
  "require": {
    "php": "^8.2",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpdocumentor/phpdocumentor": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Oasys\\Validation\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Oasys\\Validation\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "docs": "phpdoc -c phpdoc.xml.dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
